  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "undici": "^7.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
